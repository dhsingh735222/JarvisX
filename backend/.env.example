# Copy this file to `.env` and fill in the values you have.
# JarvisX runs fine with NO keys set (you can add them later from the
# Settings panel in the UI), but at least one LLM provider key is required
# for the assistant to actually respond.

ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
# Optional: leave blank to derive the encryption key from SECRET_KEY
ENCRYPTION_KEY=

# --- Database ---
# Default: local SQLite file at ../data/jarvisx.db
DATABASE_URL=sqlite:///../data/jarvisx.db
# For Docker Compose / Postgres:
# DATABASE_URL=postgresql://jarvisx:jarvisx@db:5432/jarvisx
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LLM Providers (you can also add these per-user from the Settings UI) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5
OLLAMA_BASE_URL=http://localhost:11434

# --- Voice ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
TTS_ENGINE=pyttsx3
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Filesystem sandbox ---
# Root directory the assistant is allowed to read/write. Defaults to your home directory.
WORKSPACE_ROOT=
