# Copy this file to `.env` before running `docker compose up`.
# `docker compose` automatically loads variables from a file named `.env`
# in this directory.

# --- Required ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Optional: database / cache ---
POSTGRES_PASSWORD=jarvisx

# --- Optional: encryption key for stored API keys (auto-derived from SECRET_KEY if empty) ---
ENCRYPTION_KEY=

# --- Optional: CORS (defaults allow the bundled frontend container) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Optional: server-wide default LLM keys ---
# Users can also add their own keys per-account from the Settings page.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5

# --- Optional: local model server (Ollama running on the host machine) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Optional: text-to-speech ---
TTS_ENGINE=pyttsx3
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Optional: the URL the *browser* uses to reach the backend ---
# Only relevant when building the frontend image; baked in at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
